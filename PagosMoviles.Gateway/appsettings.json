{
    "ReverseProxy": {
        "Routes": {
            "core-client-route": {
                "ClusterId": "core-cluster",
                "Match": {
                    "Path": "/gateway/admin/core/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/gateway/admin" }
                ]
            },

            "entidad-route": {
                "ClusterId": "core-cluster",
                "Match": {
                    "Path": "/gateway/admin/entidad/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/gateway/admin" }
                ]
            }
        },
        "Clusters": {
            "core-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "https://localhost:7191/"
                    }
                }
            }
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp.ReverseProxy": "Information"
        }
    },
    "AllowedHosts": "*"
}