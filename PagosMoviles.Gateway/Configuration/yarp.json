{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "usuarios-service-cluster",
        "Match": {
          "Path": "/gateway/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway" },
          { "RequestHeadersCopy": "true" }
        ]
      },

      "admin-user-route": {
        "ClusterId": "usuarios-service-cluster",
        "Match": {
          "Path": "/gateway/admin/user/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },
      "admin-rol-route": {
        "ClusterId": "usuarios-service-cluster",
        "Match": {
          "Path": "/gateway/admin/rol/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },
      "admin-parametro-route": {
        "ClusterId": "usuarios-service-cluster",
        "Match": {
          "Path": "/gateway/admin/parametro/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },
      "admin-afiliacion-route": {
        "ClusterId": "usuarios-service-cluster",
        "Match": {
          "Path": "/gateway/admin/afiliacion/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },

      "admin-entidad-route": {
        "ClusterId": "pagosmoviles-api-cluster",
        "Match": {
          "Path": "/gateway/admin/entidad/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },
      "admin-bitacora-route": {
        "ClusterId": "pagosmoviles-api-cluster",
        "Match": {
          "Path": "/gateway/admin/bitacora/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },

      "admin-core-route": {
        "ClusterId": "core-bancario-cluster",
        "Match": {
          "Path": "/gateway/admin/core/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/admin" },
          { "RequestHeadersCopy": "true" }
        ]
      },

      "trans-route": {
        "ClusterId": "pagosmoviles-api-cluster",
        "Match": {
          "Path": "/gateway/trans/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway" },
          { "RequestHeadersCopy": "true" }
        ]
      },

      "trans-balance-route": {
        "ClusterId": "core-bancario-cluster",
        "Match": {
          "Path": "/gateway/trans/accounts/balance"
        },
        "Transforms": [
          { "PathSet": "/accounts/balance" },
          { "RequestHeadersCopy": "true" }
        ]
      }
    },

    "Clusters": {
      "pagosmoviles-api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7143/"
          }
        }
      },
      "usuarios-service-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7154/"
          }
        }
      },
      "core-bancario-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7191/"
          }
        }
      }
    }
  }
}