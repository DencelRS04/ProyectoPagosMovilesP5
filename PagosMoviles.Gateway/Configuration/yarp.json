{
    "ReverseProxy": {
        "Routes": {
            "core-route": {
                "ClusterId": "core-cluster",
                "Match": { "Path": "/gateway/admin/core/{**catch-all}" },
                "Transforms": [
                    { "PathRemovePrefix": "/gateway/admin" },
                    {
                        "RequestHeader": "Authorization",
                        "Set": "{OriginalHeader:Authorization}"
                    }
                ]
            },
            "auth-route": {
                "ClusterId": "auth-cluster",
                "Match": { "Path": "/gateway/auth/{**catch-all}" },
                "Transforms": [
                    { "PathRemovePrefix": "/gateway" },
                    {
                        "RequestHeader": "Authorization",
                        "Set": "{OriginalHeader:Authorization}"
                    }
                ]
            },
            "entidad-route": {
                "ClusterId": "pagosmovil-cluster",
                "Match": { "Path": "/gateway/admin/entidad/{**catch-all}" },
                "Transforms": [
                    { "PathRemovePrefix": "/gateway/admin" },
                    {
                        "RequestHeader": "Authorization",
                        "Set": "{OriginalHeader:Authorization}"
                    }
                ]
            }
        },
        "Clusters": {
            "core-cluster": { "Destinations": { "destination1": { "Address": "https://localhost:7191/" } } },
            "auth-cluster": { "Destinations": { "destination1": { "Address": "https://localhost:7154/" } } },
            "pagosmovil-cluster": { "Destinations": { "destination1": { "Address": "https://localhost:7143/" } } }
        }
    }
}