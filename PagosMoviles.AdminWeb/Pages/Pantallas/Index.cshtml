@page
@model PagosMoviles.AdminWeb.Pages.Pantallas.IndexModel
@{
    ViewData["Title"] = "Administración de Pantallas";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .pantallas-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .pantallas-container {
        width: 95%;
        max-width: 1280px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .pantallas-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .alert-success-custom {
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .alert-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-form {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        width: 100%;
        justify-content: space-between;
    }

    .search-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 260px;
        }

        .search-box button,
        .btn-clean {
            border: none;
            padding: 10px 18px;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-box button {
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            color: white;
        }

            .search-box button:hover {
                transform: scale(1.05);
            }

    .btn-clean {
        background: #e2e8f0;
        color: #1e293b;
    }

        .btn-clean:hover {
            transform: scale(1.05);
            background: #cbd5e1;
            color: #0f172a;
        }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

        .btn-add:hover {
            transform: translateY(-3px) scale(1.03);
            color: white;
        }

    .table-responsive {
        overflow-x: auto;
    }

    .pantallas-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .pantallas-table thead th {
            text-align: left;
            padding: 12px;
            color: #475569;
            font-size: 14px;
            border: none;
            white-space: nowrap;
        }

        .pantallas-table tbody tr {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

            .pantallas-table tbody tr:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        .pantallas-table td {
            padding: 15px;
            vertical-align: middle;
            border: none;
        }

        .pantallas-table tbody tr td:first-child {
            border-radius: 16px 0 0 16px;
        }

        .pantallas-table tbody tr td:last-child {
            border-radius: 0 16px 16px 0;
        }

    .pant-id {
        font-weight: 700;
        color: #0f172a;
    }

    .pant-ruta {
        color: #1d4ed8;
        word-break: break-word;
    }

    .actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

        .actions button {
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.25s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
        color: white;
    }

        .edit:hover {
            transform: scale(1.1);
        }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

        .delete:hover {
            transform: scale(1.1);
        }

    .empty-row td {
        text-align: center;
        color: #64748b;
        font-style: italic;
        padding: 25px;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        z-index: 1050;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 28px;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        animation: aparecerModal 0.2s ease;
        max-height: 90vh;
        overflow-y: auto;
    }

        .modal-box h5 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 18px;
            color: #111827;
        }

        .modal-box p {
            color: #4b5563;
            margin-bottom: 24px;
            line-height: 1.5;
        }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

    .form-control-custom {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 13px 14px;
        font-size: 1rem;
        color: #374151;
        background: #ffffff;
        outline: none;
        transition: 0.25s;
        box-sizing: border-box;
    }

        .form-control-custom:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
        }

    textarea.form-control-custom {
        resize: vertical;
        min-height: 90px;
    }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        margin-top: 6px;
        display: block;
    }

    .modal-acciones {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .btn-cancelar {
        background: #e2e8f0;
        border: none;
        color: #1f2937;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            background: #cbd5e1;
        }

    .btn-guardar {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(37,99,235,0.30);
    }

        .btn-guardar:hover {
            transform: scale(1.03);
        }

    .btn-confirmar-eliminar {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-confirmar-eliminar:hover {
            transform: scale(1.03);
        }

    @@keyframes aparecerModal {
        from {
            opacity: 0;
            transform: translateY(10px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@media (max-width: 768px) {
        .search-box input {
            width: 100%;
            min-width: 180px;
        }

        .search-form {
            align-items: stretch;
        }

        .search-left {
            width: 100%;
        }

        .modal-acciones {
            flex-direction: column;
        }

        .btn-cancelar,
        .btn-guardar,
        .btn-confirmar-eliminar {
            width: 100%;
        }
    }
</style>

<div class="pantallas-wrapper">
    <div class="pantallas-container">
        <h2 class="pantallas-title">Administración de Pantallas</h2>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert-success-custom">✅ @TempData["Mensaje"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-danger-custom">⚠️ @TempData["Error"]</div>
        }

        @if (Model.MensajeError != null)
        {
            <div class="alert-danger-custom">⚠️ @Model.MensajeError</div>
        }

        <div class="top-bar">
            <form method="get" class="search-form">
                <div class="search-left">
                    <div class="search-box">
                        <input type="text"
                               name="buscar"
                               value="@Model.Buscar"
                               placeholder="Buscar por nombre o identificador..." />
                        <button type="submit">Buscar</button>
                    </div>

                    <a asp-page="Index" class="btn-clean">Limpiar</a>
                </div>

                <div>
                    <button type="button" class="btn-add" onclick="abrirModalCrear()">+ Nueva Pantalla</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="pantallas-table">
                <thead>
                    <tr>
                        <th>Identificador</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Ruta</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Pantallas.Any())
                    {
                        <tr class="empty-row">
                            <td colspan="5">No se encontraron pantallas registradas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.Pantallas)
                        {
                            <tr>
                                <td><span class="pant-id">@p.Identificador</span></td>
                                <td>@p.Nombre</td>
                                <td>@p.Descripcion</td>
                                <td><span class="pant-ruta">@p.Ruta</span></td>
                                <td>
                                    <div class="actions">
                                        <button type="button"
                                                class="edit"
                                                onclick="abrirModalEditar(@p.PantallaId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Identificador))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Nombre))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Descripcion))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Ruta))')">
                                            Editar
                                        </button>

                                        <button type="button"
                                                class="delete"
                                                onclick="confirmarEliminar(@p.PantallaId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Nombre))')">
                                            Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL CREAR -->
<div class="modal-overlay" id="modalCrear">
    <div class="modal-box">
        <h5>Nueva Pantalla</h5>

        <form method="post" asp-page-handler="Crear">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="NuevaPantalla.Identificador">Identificador</label>
                <input asp-for="NuevaPantalla.Identificador" class="form-control-custom" placeholder="Ej: PANT001" />
                <span asp-validation-for="NuevaPantalla.Identificador" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NuevaPantalla.Nombre">Nombre</label>
                <input asp-for="NuevaPantalla.Nombre" class="form-control-custom" placeholder="Nombre de la pantalla" />
                <span asp-validation-for="NuevaPantalla.Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NuevaPantalla.Descripcion">Descripción</label>
                <textarea asp-for="NuevaPantalla.Descripcion" class="form-control-custom" placeholder="Descripción de la pantalla"></textarea>
                <span asp-validation-for="NuevaPantalla.Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NuevaPantalla.Ruta">Ruta de acceso</label>
                <input asp-for="NuevaPantalla.Ruta" class="form-control-custom" placeholder="Ej: /Pantallas/Index" />
                <span asp-validation-for="NuevaPantalla.Ruta" class="text-danger"></span>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalCrear()">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDITAR -->
<div class="modal-overlay" id="modalEditar">
    <div class="modal-box">
        <h5>Editar Pantalla</h5>

        <form method="post" asp-page-handler="Editar">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" id="editId" />

            <div class="form-group">
                <label asp-for="Pantalla.Identificador">Identificador</label>
                <input asp-for="Pantalla.Identificador" class="form-control-custom" id="editIdentificador" />
                <span asp-validation-for="Pantalla.Identificador" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Pantalla.Nombre">Nombre</label>
                <input asp-for="Pantalla.Nombre" class="form-control-custom" id="editNombre" />
                <span asp-validation-for="Pantalla.Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Pantalla.Descripcion">Descripción</label>
                <textarea asp-for="Pantalla.Descripcion" class="form-control-custom" id="editDescripcion"></textarea>
                <span asp-validation-for="Pantalla.Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Pantalla.Ruta">Ruta de acceso</label>
                <input asp-for="Pantalla.Ruta" class="form-control-custom" id="editRuta" />
                <span asp-validation-for="Pantalla.Ruta" class="text-danger"></span>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalEditar()">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar cambios</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL ELIMINAR -->
<div class="modal-overlay" id="modalEliminar">
    <div class="modal-box">
        <h5>Confirmar eliminación</h5>
        <p>¿Realmente desea eliminar la pantalla <strong id="nombrePantalla"></strong>?</p>

        <div class="modal-acciones">
            <button type="button" class="btn-cancelar" onclick="cerrarModalEliminar()">No</button>

            <form method="post" asp-page-handler="Eliminar" id="formEliminar">
                <input type="hidden" name="id" id="idEliminar" />
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-confirmar-eliminar">Sí, eliminar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function abrirModalCrear() {
            document.getElementById('modalCrear').classList.add('activo');
        }

        function cerrarModalCrear() {
            document.getElementById('modalCrear').classList.remove('activo');
        }

        function abrirModalEditar(id, identificador, nombre, descripcion, ruta) {
            document.getElementById('editId').value = id;
            document.getElementById('editIdentificador').value = identificador;
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editDescripcion').value = descripcion;
            document.getElementById('editRuta').value = ruta;
            document.getElementById('modalEditar').classList.add('activo');
        }

        function cerrarModalEditar() {
            document.getElementById('modalEditar').classList.remove('activo');
        }

        function confirmarEliminar(id, nombre) {
            document.getElementById('idEliminar').value = id;
            document.getElementById('nombrePantalla').textContent = nombre;
            document.getElementById('modalEliminar').classList.add('activo');
        }

        function cerrarModalEliminar() {
            document.getElementById('modalEliminar').classList.remove('activo');
        }

        document.getElementById('modalCrear').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalCrear();
        });

        document.getElementById('modalEditar').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEditar();
        });

        document.getElementById('modalEliminar').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEliminar();
        });
    </script>
}
}