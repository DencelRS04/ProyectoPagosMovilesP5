@page
@model PagosMoviles.AdminWeb.Pages.Home.IndexModel
@{
    ViewData["Title"] = "HOME";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(rgba(10,31,68,0.8), rgba(10,31,68,0.9)), url('https://images.unsplash.com/photo-1554224155-6726b3ff858f');
        background-size: cover;
        background-position: center;
    }

    .dashboard-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
        position: relative;
    }

    /* USUARIO ARRIBA DERECHA */
    .user-info {
        position: absolute;
        top: 20px;
        right: 30px;
        color: white;
        font-size: 0.9rem;
        opacity: 0.85;
    }

    /* TARJETA PRINCIPAL */
    .dashboard-card {
        backdrop-filter: blur(12px);
        background: rgba(255,255,255,0.06);
        padding: 60px;
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.15);
        box-shadow: 0 15px 50px rgba(0,0,0,0.4);
        text-align: center;
        color: white;
        max-width: 700px;
        animation: fadeIn 0.6s ease;
    }

        .dashboard-card h1 {
            font-size: 2.8rem;
            font-weight: 300;
            margin-bottom: 15px;
        }

        .dashboard-card h2 {
            font-size: 2rem;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .dashboard-card p {
            margin-top: 15px;
            opacity: 0.85;
            font-size: 1rem;
        }

    /* EFECTO */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .dashboard-card {
            padding: 30px;
        }

            .dashboard-card h1 {
                font-size: 2rem;
            }

            .dashboard-card h2 {
                font-size: 1.5rem;
            }
    }
</style>

<div class="dashboard-wrapper">

    <!-- CONTENIDO -->
    <div class="dashboard-card">
        <h1>Bienvenido, @Model.UsuarioNombre, al panel administrativo de </h1>
        <h2>DAYJA BANK</h2>

        <p>
            Donde se hace la magia ✨
            <br />
            Gestione, controle y supervise todas las operaciones del sistema de manera segura.
        </p>
    </div>

</div>