@page
@model PagosMoviles.AdminWeb.Pages.Home.IndexModel
@{
    ViewData["Title"] = "HOME";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(rgba(10,31,68,0.8), rgba(10,31,68,0.9)), url('https://images.unsplash.com/photo-1554224155-6726b3ff858f');
        background-size: cover;
        background-position: center;
    }

    .dashboard-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
        position: relative;
    }

    .user-info {
        position: absolute;
        top: 20px;
        right: 30px;
        color: white;
        font-size: 0.9rem;
        opacity: 0.85;
    }

    .dashboard-card {
        backdrop-filter: blur(12px);
        background: rgba(255,255,255,0.06);
        padding: 60px;
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.15);
        box-shadow: 0 15px 50px rgba(0,0,0,0.4);
        text-align: center;
        color: white;
        max-width: 700px;
        animation: fadeIn 0.6s ease;
    }

        .dashboard-card h1 {
            font-size: 2.8rem;
            font-weight: 300;
            margin-bottom: 15px;
        }

        .dashboard-card h2 {
            font-size: 2rem;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .dashboard-card p {
            margin-top: 15px;
            opacity: 0.85;
            font-size: 1rem;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.75);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 28px;
        max-width: 420px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        text-align: center;
    }

        .modal-box h5 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 10px;
            color: #111827;
        }

        .modal-box p {
            color: #4b5563;
            margin-bottom: 25px;
            line-height: 1.5;
        }

    .modal-acciones {
        display: flex;
        justify-content: center;
    }

    .btn-confirmar-modal {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-confirmar-modal:hover {
            transform: scale(1.03);
        }

    @@media (max-width: 768px) {
        .dashboard-card {
            padding: 30px;
        }

            .dashboard-card h1 {
                font-size: 2rem;
            }

            .dashboard-card h2 {
                font-size: 1.5rem;
            }
    }
</style>

<div class="dashboard-wrapper">
    <div class="dashboard-card">
        <h1>
            Bienvenido, @Model.UsuarioNombre
            <!--, al panel administrativo de-->
        </h1>
        <!-- <h2>DAYJA BANK</h2>

        <p>
            Donde se hace la magia ✨
            <br />
            Gestione, controle y supervise todas las operaciones del sistema de manera segura.
        </p>-->
    </div>
</div>

<div class="modal-overlay" id="modalSesionExpirada">
    <div class="modal-box">
        <h5>Sesión expirada</h5>
        <p id="mensajeSesionExpirada"></p>

        <div class="modal-acciones">
            <button type="button" class="btn-confirmar-modal" onclick="redirigirIndex()">
                Aceptar
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function redirigirIndex() {
            window.location.href = "/Index";
        }

        document.addEventListener("DOMContentLoaded", function () {
            var mensaje = '@Html.Raw((TempData["SesionExpirada"]?.ToString() ?? "").Replace("'", "\\'"))';

            if (mensaje !== '') {
                document.getElementById("mensajeSesionExpirada").textContent = mensaje;
                document.getElementById("modalSesionExpirada").classList.add("activo");

                document.body.style.pointerEvents = "none";
                document.getElementById("modalSesionExpirada").style.pointerEvents = "all";
            }
        });
    </script>
}
