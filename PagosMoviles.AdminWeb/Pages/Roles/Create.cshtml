@page
@model PagosMoviles.AdminWeb.Pages.Roles.CreateModel
@{
    ViewData["Title"] = "Nuevo Rol";
}

<style>
    .form-card { background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 2rem; max-width: 560px; }
    .form-title { font-size: 1.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1.75rem; }
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-weight: 600; color: #333; margin-bottom: 0.4rem; font-size: 0.95rem; }
    .form-group input[type="text"] { width: 100%; border: 1px solid #ced4da; border-radius: 6px; padding: 0.5rem 0.75rem; font-size: 0.95rem; box-sizing: border-box; }
    .form-group input[type="text"]:focus { outline: none; border-color: #0d6efd; box-shadow: 0 0 0 3px rgba(13,110,253,.15); }
    .text-danger { color: #dc3545; font-size: 0.82rem; margin-top: 0.25rem; display: block; }
    .pantallas-container { border: 1px solid #ced4da; border-radius: 6px; padding: 0.75rem; max-height: 200px; overflow-y: auto; background: #fafafa; }
    .pantalla-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.5rem; border-radius: 4px; transition: background 0.15s; }
    .pantalla-item:hover { background: #f0f4ff; }
    .pantalla-item input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; accent-color: #0d6efd; }
    .pantalla-item label { font-size: 0.92rem; color: #333; cursor: pointer; margin: 0; font-weight: 400; }
    .sin-pantallas { color: #888; font-size: 0.9rem; text-align: center; padding: 1rem; }
    .form-acciones { display: flex; gap: 0.75rem; margin-top: 1.75rem; }
    .btn-guardar { background: #0d6efd; color: white; border: none; padding: 0.55rem 1.5rem; border-radius: 6px; font-weight: 600; cursor: pointer; }
    .btn-guardar:hover { background: #0b5ed7; }
    .btn-volver { background: white; color: #555; border: 1px solid #ced4da; padding: 0.55rem 1.25rem; border-radius: 6px; font-weight: 600; text-decoration: none; }
    .btn-volver:hover { background: #f8f9fa; }
    .alert-danger { background: #f8d7da; color: #842029; border: 1px solid #f5c2c7; border-radius: 6px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; }
</style>

<div class="container mt-4">
    <div class="form-card">
        <h1 class="form-title">Nuevo Rol</h1>

        @if (Model.MensajeError != null)
        {
            <div class="alert-danger">⚠️ @Model.MensajeError</div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="NuevoRol.Nombre">Nombre del Rol</label>
                <input asp-for="NuevoRol.Nombre" type="text" placeholder="Ej: Administrador" />
                <span asp-validation-for="NuevoRol.Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Pantallas asociadas</label>
                <div class="pantallas-container">
                    @if (!Model.Pantallas.Any())
                    {
                        <p class="sin-pantallas">No hay pantallas disponibles.</p>
                    }
                    else
                    {
                        @foreach (var p in Model.Pantallas)
                        {
                            <div class="pantalla-item">
                                <input type="checkbox" name="PantallasSeleccionadas"
                                       value="@p.PantallaId" id="pant_@p.PantallaId" />
                                <label for="pant_@p.PantallaId">@p.Nombre — @p.Ruta</label>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="form-acciones">
                <button type="submit" class="btn-guardar">💾 Guardar</button>
                <a asp-page="Index" class="btn-volver">← Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
