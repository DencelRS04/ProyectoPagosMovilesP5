@page
@model PagosMoviles.AdminWeb.Pages.ClientesCore.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .clientes-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .clientes-container {
        width: 95%;
        max-width: 1300px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .clientes-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-form {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        width: 100%;
        justify-content: space-between;
    }

    .search-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 280px;
        }

        .search-box button,
        .btn-clean {
            border: none;
            padding: 10px 18px;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-box button {
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            color: white;
        }

    .btn-clean {
        background: #e2e8f0;
        color: #1e293b;
    }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
    }

    .table-responsive {
        overflow-x: auto;
    }

    .clientes-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .clientes-table thead th {
            text-align: left;
            padding: 12px;
            color: #475569;
            font-size: 14px;
            border: none;
            white-space: nowrap;
        }

        .clientes-table tbody tr {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

        .clientes-table td {
            padding: 15px;
            vertical-align: middle;
            border: none;
        }

    .estado {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .estado-activo {
        background: linear-gradient(135deg, #dcfce7, #86efac);
        color: #166534;
    }

    .estado-inactivo {
        background: linear-gradient(135deg, #fee2e2, #fca5a5);
        color: #991b1b;
    }

    .actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

        .actions button {
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
        }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
        color: white;
    }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

    .empty-row td {
        text-align: center;
        color: #64748b;
        font-style: italic;
        padding: 25px;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        z-index: 1050;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 28px;
        max-width: 620px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        max-height: 90vh;
        overflow-y: auto;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

    .form-control-custom {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 13px 14px;
        font-size: 1rem;
        color: #374151;
        background: #ffffff;
        outline: none;
        box-sizing: border-box;
    }

    .check-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
    }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        margin-top: 6px;
        display: block;
    }

    .modal-acciones {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .btn-cancelar {
        background: #e2e8f0;
        border: none;
        color: #1f2937;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-guardar {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-confirmar-eliminar {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
    }
</style>

<div class="clientes-wrapper">
    <div class="clientes-container">
        <h2 class="clientes-title">Clientes Core</h2>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success mb-3">
                @TempData["MensajeExito"]
            </div>
        }

        <div class="top-bar">
            <form method="get" class="search-form">
                <div class="search-left">
                    <div class="search-box">
                        <input type="text" name="Busqueda" value="@Model.Busqueda" placeholder="Buscar por identificación, nombre o teléfono..." />
                        <button type="submit">Buscar</button>
                    </div>

                    <a asp-page="/ClientesCore/Index" class="btn-clean">Limpiar</a>
                </div>

                <div>
                    <button type="button" class="btn-add" onclick="abrirModalCrearCliente()">+ Nuevo Cliente</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="clientes-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Identificación</th>
                        <th>Tipo</th>
                        <th>Nombre</th>
                        <th>Fecha Nacimiento</th>
                        <th>Teléfono</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Clientes != null && Model.Clientes.Any())
                    {
                        @foreach (var item in Model.Clientes)
                        {
                            <tr>
                                <td>@item.ClienteId</td>
                                <td>@item.Identificacion</td>
                                <td>@item.TipoIdentificacion</td>
                                <td>@item.NombreCompleto</td>
                                <td>@(item.FechaNacimiento?.ToString("yyyy-MM-dd") ?? "")</td>
                                <td>@item.Telefono</td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="estado estado-activo">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="estado estado-inactivo">No</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions">
                                        <button type="button"
                                                class="edit"
                                                onclick="abrirModalEditarCliente(
                                            '@item.ClienteId',
                                            '@Html.Raw((item.Identificacion ?? "").Replace("'", "\\'"))',
                                            '@Html.Raw((item.TipoIdentificacion ?? "").Replace("'", "\\'"))',
                                            '@Html.Raw((item.NombreCompleto ?? "").Replace("'", "\\'"))',
                                            '@(item.FechaNacimiento?.ToString("yyyy-MM-dd") ?? "")',
                                            '@Html.Raw((item.Telefono ?? "").Replace("'", "\\'"))',
                                            '@item.Activo.ToString().ToLower()'
                                            )">
                                            Editar
                                        </button>

                                        <button type="button"
                                                class="delete"
                                                onclick="abrirModalEliminarCliente('@item.ClienteId', '@Html.Raw((item.NombreCompleto ?? "").Replace("'", "\\'"))')">
                                            Desactivar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="empty-row">
                            <td colspan="8">No se encontraron clientes.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalCrearCliente">
    <div class="modal-box">
        <h5>Nuevo Cliente</h5>

        <form method="post" asp-page-handler="Crear" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Cliente.Identificacion"></label>
                <input asp-for="Cliente.Identificacion" class="form-control-custom" />
                <span asp-validation-for="Cliente.Identificacion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cliente.TipoIdentificacion"></label>
                <input asp-for="Cliente.TipoIdentificacion" class="form-control-custom" />
                <span asp-validation-for="Cliente.TipoIdentificacion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cliente.NombreCompleto"></label>
                <input asp-for="Cliente.NombreCompleto" class="form-control-custom" />
                <span asp-validation-for="Cliente.NombreCompleto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cliente.FechaNacimiento"></label>
                <input asp-for="Cliente.FechaNacimiento" type="date" class="form-control-custom" />
                <span asp-validation-for="Cliente.FechaNacimiento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cliente.Telefono"></label>
                <input asp-for="Cliente.Telefono" class="form-control-custom" />
                <span asp-validation-for="Cliente.Telefono" class="text-danger"></span>
            </div>

            <div class="check-wrap">
                <input asp-for="Cliente.Activo" />
                <label asp-for="Cliente.Activo"></label>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalCrearCliente()">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="modalEditarCliente">
    <div class="modal-box">
        <h5>Editar Cliente</h5>

        <form method="post" asp-page-handler="Editar" id="formEditarCliente" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ClienteEditar.ClienteId" id="editClienteId" />
            <div class="form-group">
                <label asp-for="ClienteEditar.Identificacion"></label>
                <input asp-for="ClienteEditar.Identificacion" id="editIdentificacion" class="form-control-custom" />
                <span asp-validation-for="ClienteEditar.Identificacion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClienteEditar.TipoIdentificacion"></label>
                <input asp-for="ClienteEditar.TipoIdentificacion" id="editTipoIdentificacion" class="form-control-custom" />
                <span asp-validation-for="ClienteEditar.TipoIdentificacion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClienteEditar.NombreCompleto"></label>
                <input asp-for="ClienteEditar.NombreCompleto" id="editNombreCompleto" class="form-control-custom" />
                <span asp-validation-for="ClienteEditar.NombreCompleto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClienteEditar.FechaNacimiento"></label>
                <input asp-for="ClienteEditar.FechaNacimiento" id="editFechaNacimiento" type="date" class="form-control-custom" />
                <span asp-validation-for="ClienteEditar.FechaNacimiento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClienteEditar.Telefono"></label>
                <input asp-for="ClienteEditar.Telefono" id="editTelefono" class="form-control-custom" />
                <span asp-validation-for="ClienteEditar.Telefono" class="text-danger"></span>
            </div>

            <div class="check-wrap">
                <input asp-for="ClienteEditar.Activo" id="editActivo" />
                <label asp-for="ClienteEditar.Activo"></label>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalEditarCliente()">Cancelar</button>
                <button type="submit" class="btn-guardar">Actualizar</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="modalEliminarCliente">
    <div class="modal-box">
        <h5>Confirmar desactivación</h5>
        <p>¿Realmente desea desactivar al cliente <strong id="nombreClienteEliminar"></strong>?</p>

        <div class="modal-acciones">
            <button type="button" class="btn-cancelar" onclick="cerrarModalEliminarCliente()">No</button>

            <form method="post" asp-page-handler="Eliminar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteClienteId" />
                <button type="submit" class="btn-confirmar-eliminar">Sí, desactivar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (ViewData["AbrirModalCrear"] as bool? == true)
    {
        <script>
            abrirModalCrearCliente();
        </script>
    }

    @if (ViewData["AbrirModalEditar"] as bool? == true)
    {
        <script>
            abrirModalEditarCliente(
                '@Model.ClienteEditar.ClienteId',
                '@Html.Raw((Model.ClienteEditar.Identificacion ?? "").Replace("'", "\\'"))',
                '@Html.Raw((Model.ClienteEditar.TipoIdentificacion ?? "").Replace("'", "\\'"))',
                '@Html.Raw((Model.ClienteEditar.NombreCompleto ?? "").Replace("'", "\\'"))',
                '@(Model.ClienteEditar.FechaNacimiento?.ToString("yyyy-MM-dd") ?? "")',
                '@Html.Raw((Model.ClienteEditar.Telefono ?? "").Replace("'", "\\'"))',
                '@Model.ClienteEditar.Activo.ToString().ToLower()'
            );
        </script>
    }

    <script>
        function abrirModalCrearCliente() {
            document.getElementById('modalCrearCliente').classList.add('activo');
        }

        function cerrarModalCrearCliente() {
            document.getElementById('modalCrearCliente').classList.remove('activo');
        }

        function abrirModalEditarCliente(id, identificacion, tipo, nombre, fecha, telefono, activo) {
            document.getElementById('editClienteId').value = id;
            document.getElementById('editIdentificacion').value = identificacion;
            document.getElementById('editTipoIdentificacion').value = tipo;
            document.getElementById('editNombreCompleto').value = nombre;
            document.getElementById('editFechaNacimiento').value = fecha;
            document.getElementById('editTelefono').value = telefono;
            document.getElementById('editActivo').checked = (activo === 'true');

            document.getElementById('formEditarCliente').action = '?handler=Editar&id=' + id;
            document.getElementById('modalEditarCliente').classList.add('activo');
        }

        function cerrarModalEditarCliente() {
            document.getElementById('modalEditarCliente').classList.remove('activo');
        }

        function abrirModalEliminarCliente(id, nombre) {
            document.getElementById('deleteClienteId').value = id;
            document.getElementById('nombreClienteEliminar').textContent = nombre;
            document.getElementById('modalEliminarCliente').classList.add('activo');
        }

        function cerrarModalEliminarCliente() {
            document.getElementById('modalEliminarCliente').classList.remove('activo');
        }

        document.getElementById('modalCrearCliente').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalCrearCliente();
        });

        document.getElementById('modalEditarCliente').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEditarCliente();
        });

        document.getElementById('modalEliminarCliente').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEliminarCliente();
        });
    </script>
}