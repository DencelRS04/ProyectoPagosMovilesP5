@page
@model PagosMoviles.AdminWeb.Pages.ClientesCore.CreateModel

<h2>Nuevo Cliente</h2>

<form method="post">
    <div class="mb-3">
        <label asp-for="Cliente.Identificacion"></label>
        <input asp-for="Cliente.Identificacion" class="form-control" />
        <span asp-validation-for="Cliente.Identificacion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cliente.TipoIdentificacion"></label>
        <input asp-for="Cliente.TipoIdentificacion" class="form-control" />
        <span asp-validation-for="Cliente.TipoIdentificacion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cliente.NombreCompleto"></label>
        <input asp-for="Cliente.NombreCompleto" class="form-control" />
        <span asp-validation-for="Cliente.NombreCompleto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cliente.FechaNacimiento"></label>
        <input asp-for="Cliente.FechaNacimiento" type="date" class="form-control" />
        <span asp-validation-for="Cliente.FechaNacimiento" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cliente.Telefono"></label>
        <input asp-for="Cliente.Telefono" class="form-control" />
        <span asp-validation-for="Cliente.Telefono" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Cliente.Activo" class="form-check-input" />
        <label asp-for="Cliente.Activo" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}