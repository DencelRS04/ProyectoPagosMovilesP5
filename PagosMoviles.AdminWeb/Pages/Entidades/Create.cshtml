@page
@model PagosMoviles.AdminWeb.Pages.Entidades.CreateModel
@{
    ViewData["Title"] = "Crear Nueva Entidad";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">
                <i class="fas fa-plus-circle me-2"></i>Crear Nueva Entidad
            </h3>
        </div>

        <div class="card-body">
            <form method="post" id="createForm">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-8 mx-auto">
                        <div class="mb-4">
                            <label asp-for="Entidad.Identificador" class="form-label fw-bold">
                                <i class="fas fa-id-card me-2"></i>Identificador
                            </label>
                            <input asp-for="Entidad.Identificador"
                                   class="form-control form-control-lg"
                                   placeholder="Ingrese el identificador único"
                                   required
                                   maxlength="50" />
                            <span asp-validation-for="Entidad.Identificador" class="text-danger small"></span>
                            <div class="form-text">El identificador debe ser único en el sistema.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Entidad.Nombre" class="form-label fw-bold">
                                <i class="fas fa-building me-2"></i>Nombre
                            </label>
                            <input asp-for="Entidad.Nombre"
                                   class="form-control form-control-lg"
                                   placeholder="Ingrese el nombre de la entidad"
                                   required
                                   maxlength="100" />
                            <span asp-validation-for="Entidad.Nombre" class="text-danger small"></span>
                            <div class="form-text">Nombre completo de la entidad.</div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary btn-lg" onclick="history.back()">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </button>
                            <button type="submit" class="btn btn-success btn-lg" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Guardar Entidad
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle text-info me-2"></i>
                <small class="text-muted">
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </small>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
        }

        .card-header {
            border-bottom: none;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #e0e0e0;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.25);
                border-color: #28a745;
            }

        .form-control-lg {
            font-size: 1rem;
        }

        .btn {
            border-radius: 10px;
            padding: 12px 25px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

        .btn-success:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            border-color: #545b62;
        }

        .card-footer {
            background-color: #f8f9fa;
            border-top: 1px solid #e9ecef;
        }

        .form-text {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .text-danger {
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            animation: fadeIn 0.5s ease-out;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('createForm');
            const submitBtn = document.getElementById('btnSubmit');

            // Prevenir múltiples envíos
            form.addEventListener('submit', function() {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';
            });

            // Validación personalizada
            const inputs = document.querySelectorAll('input[required]');
            inputs.forEach(input => {
                input.addEventListener('invalid', function(e) {
                    e.preventDefault();
                    this.classList.add('is-invalid');
                });

                input.addEventListener('input', function() {
                    if (this.validity.valid) {
                        this.classList.remove('is-invalid');
                    }
                });
            });

            // Auto-mayúsculas para el identificador (opcional)
            const identificador = document.querySelector('[name="Entidad.Identificador"]');
            if (identificador) {
                identificador.addEventListener('input', function() {
                    this.value = this.value.toUpperCase().replace(/\s/g, '');
                });
            }

            // Capitalizar nombre
            const nombre = document.querySelector('[name="Entidad.Nombre"]');
            if (nombre) {
                nombre.addEventListener('input', function() {
                    let words = this.value.toLowerCase().split(' ');
                    for (let i = 0; i < words.length; i++) {
                        if (words[i].length > 0) {
                            words[i] = words[i][0].toUpperCase() + words[i].substr(1);
                        }
                    }
                    this.value = words.join(' ');
                });
            }

            // Confirmación antes de salir sin guardar
            let formChanged = false;

            inputs.forEach(input => {
                input.addEventListener('change', function() {
                    formChanged = true;
                });
            });

            window.addEventListener('beforeunload', function(e) {
                if (formChanged && !submitBtn.disabled) {
                    e.preventDefault();
                    e.returnValue = '';
                }
            });

            // Botón cancelar personalizado
            const cancelBtn = document.querySelector('button[onclick="history.back()"]');
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (formChanged) {
                        if (confirm('¿Estás seguro de que deseas cancelar? Los cambios no guardados se perderán.')) {
                            window.location.href = '/Entidades/Index';
                        }
                    } else {
                        window.location.href = '/Entidades/Index';
                    }
                });
            }
        });
    </script>
}

