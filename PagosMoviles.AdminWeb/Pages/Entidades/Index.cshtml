@page
@model PagosMoviles.AdminWeb.Pages.Entidades.IndexModel
@{
    ViewData["Title"] = "Administración de Entidades Bancarias";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .entidades-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .entidades-container {
        width: 95%;
        max-width: 1200px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .entidades-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .alert-success-custom {
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .alert-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 260px;
        }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-3px) scale(1.03);
        }

    .table-responsive {
        overflow-x: auto;
    }

    .entidades-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .entidades-table thead th {
            text-align: left;
            padding: 12px;
            color: #475569;
            font-size: 14px;
            border: none;
        }

        .entidades-table tbody tr {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

            .entidades-table tbody tr:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        .entidades-table td {
            padding: 15px;
            vertical-align: middle;
            border: none;
        }

        .entidades-table tbody tr td:first-child {
            border-radius: 16px 0 0 16px;
        }

        .entidades-table tbody tr td:last-child {
            border-radius: 0 16px 16px 0;
        }

    .actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

        .actions button {
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.25s;
        }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
        color: white;
    }

        .edit:hover {
            transform: scale(1.1);
        }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

        .delete:hover {
            transform: scale(1.1);
        }

    .empty-row td {
        text-align: center;
        color: #64748b;
        font-style: italic;
        padding: 25px;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        z-index: 1050;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 28px;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        max-height: 90vh;
        overflow-y: auto;
    }

        .modal-box h5 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 18px;
            color: #111827;
        }

        .modal-box p {
            color: #4b5563;
            margin-bottom: 24px;
            line-height: 1.5;
        }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

    .form-control-custom {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 13px 14px;
        font-size: 1rem;
        color: #374151;
        background: #ffffff;
        outline: none;
        transition: 0.25s;
        box-sizing: border-box;
    }

        .form-control-custom:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
        }

        .form-control-custom[readonly],
        .form-control-custom[disabled] {
            background: #f8fafc;
            cursor: not-allowed;
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
        margin-top: 6px;
        display: block;
    }

    .help-text {
        color: #6b7280;
        font-size: 0.85rem;
        margin-top: 6px;
    }

    .modal-acciones {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .btn-cancelar {
        background: #e2e8f0;
        border: none;
        color: #1f2937;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            background: #cbd5e1;
        }

    .btn-guardar {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(37,99,235,0.30);
    }

        .btn-guardar:hover {
            transform: scale(1.03);
        }

    .btn-confirmar-eliminar {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-confirmar-eliminar:hover {
            transform: scale(1.03);
        }

    @@media (max-width: 768px) {
        .search-box input {
            width: 100%;
            min-width: 180px;
        }

        .modal-acciones {
            flex-direction: column;
        }

        .btn-cancelar,
        .btn-guardar,
        .btn-confirmar-eliminar {
            width: 100%;
        }
    }
</style>

<div class="entidades-wrapper">
    <div class="entidades-container">
        <h2 class="entidades-title">Administración de Entidades Bancarias</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert-danger-custom">@TempData["Error"]</div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
        {
            <div class="alert-danger-custom">@Model.ErrorMensaje</div>
        }

        <div class="top-bar">
            <div class="search-box">
                <input type="text" id="buscar" placeholder="Buscar por identificador" />
            </div>

            <button type="button" class="btn-add" onclick="abrirModalCrear()">+ Nueva Entidad</button>
        </div>

        <div class="table-responsive">
            <table class="entidades-table" id="tablaEntidades">
                <thead>
                    <tr>
                        <th>Identificador</th>
                        <th>Nombre</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entidades != null && Model.Entidades.Any())
                    {
                        @foreach (var entidad in Model.Entidades)
                        {
                            <tr>
                                <td>@entidad.CodigoEntidad</td>
                                <td>@entidad.NombreInstitucion</td>
                                <td>
                                    <div class="actions">
                                        <button type="button"
                                                class="edit"
                                                onclick="abrirModalEditar('@entidad.EntidadId', '@entidad.CodigoEntidad', '@Html.Raw(entidad.NombreInstitucion?.Replace("'", "\\'"))')">
                                            Editar
                                        </button>

                                        <form method="post"
                                              asp-page-handler="Eliminar"
                                              asp-route-id="@entidad.CodigoEntidad"
                                              style="display:inline">
                                            <button type="submit"
                                                    class="delete"
                                                    onclick="return confirm('¿Desea eliminar esta entidad?')">
                                                Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="empty-row">
                            <td colspan="3">No se encontraron entidades registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL CREAR -->
<div class="modal-overlay" id="modalCrear">
    <div class="modal-box">
        <h5>Nueva Entidad</h5>

        <form method="post" asp-page-handler="Crear">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Entidad.CodigoEntidad">Identificador</label>
                <input asp-for="Entidad.CodigoEntidad" class="form-control-custom" placeholder="Ej: 101" />
                <span asp-validation-for="Entidad.CodigoEntidad" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Entidad.NombreInstitucion">Nombre</label>
                <input asp-for="Entidad.NombreInstitucion" class="form-control-custom" placeholder="Ingrese el nombre de la entidad" />
                <span asp-validation-for="Entidad.NombreInstitucion" class="text-danger"></span>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalCrear()">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDITAR -->
<div class="modal-overlay" id="modalEditar">
    <div class="modal-box">
        <h5>Editar Entidad</h5>

        <form method="post" asp-page-handler="Editar">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="EntidadEditar.EntidadId" id="editEntidadId" />
            <input type="hidden" asp-for="EntidadEditar.CodigoEntidad" id="editCodigoEntidadHidden" />

            <div class="form-group">
                <label>Identificador</label>
                <input type="text" class="form-control-custom" id="editCodigoEntidadVisible" readonly disabled />
                <div class="help-text">El identificador no puede ser modificado.</div>
            </div>

            <div class="form-group">
                <label asp-for="EntidadEditar.NombreInstitucion">Nombre</label>
                <input asp-for="EntidadEditar.NombreInstitucion"
                       class="form-control-custom"
                       id="editNombreInstitucion"
                       placeholder="Ingrese el nombre de la entidad" />
                <span asp-validation-for="EntidadEditar.NombreInstitucion" class="text-danger"></span>
            </div>

            <div class="modal-acciones">
                <button type="button" class="btn-cancelar" onclick="cerrarModalEditar()">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("buscar").addEventListener("keyup", function () {
            let filtro = this.value.toLowerCase();
            let filas = document.querySelectorAll("#tablaEntidades tbody tr");

            filas.forEach(fila => {
                let id = fila.children[0].textContent.toLowerCase();
                fila.style.display = id.includes(filtro) ? "" : "none";
            });
        });

        function abrirModalCrear() {
            document.getElementById('modalCrear').classList.add('activo');
        }

        function cerrarModalCrear() {
            document.getElementById('modalCrear').classList.remove('activo');
        }

        function abrirModalEditar(entidadId, codigoEntidad, nombreInstitucion) {
            document.getElementById('editEntidadId').value = entidadId;
            document.getElementById('editCodigoEntidadHidden').value = codigoEntidad;
            document.getElementById('editCodigoEntidadVisible').value = codigoEntidad;
            document.getElementById('editNombreInstitucion').value = nombreInstitucion;
            document.getElementById('modalEditar').classList.add('activo');
        }

        function cerrarModalEditar() {
            document.getElementById('modalEditar').classList.remove('activo');
        }

        document.getElementById('modalCrear').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalCrear();
        });

        document.getElementById('modalEditar').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEditar();
        });
    </script>
}