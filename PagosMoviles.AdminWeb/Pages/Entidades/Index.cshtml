@page
@model PagosMoviles.AdminWeb.Pages.Entidades.IndexModel
@{
    ViewData["Title"] = "Administración de Entidades";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .container {
        width: 95%;
        max-width: 1200px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    h2 {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        padding: 12px 15px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
        gap: 6px;
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 260px;
            font-size: 14px;
        }

        .search-box button,
        .search-box a {
            border: none;
            padding: 10px 18px;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

    .btn-search {
        background: linear-gradient(135deg, #3b82f6, #1e3a8a);
        color: white;
    }

        .btn-search:hover {
            transform: scale(1.05);
        }

    .btn-clear {
        background: #dbe2ea;
        color: #334155;
    }

        .btn-clear:hover {
            transform: scale(1.05);
        }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-3px) scale(1.03);
        }

    table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    thead th {
        text-align: left;
        padding: 12px;
        color: #475569;
        font-size: 14px;
    }

    tbody tr {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.25s;
    }

        tbody tr:hover {
            transform: translateY(-3px) scale(1.01);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    td {
        padding: 15px;
        color: #1f2937;
    }

    tbody tr td:first-child {
        border-radius: 16px 0 0 16px;
        font-weight: 600;
    }

    tbody tr td:last-child {
        border-radius: 0 16px 16px 0;
    }

    .actions button {
        border: none;
        padding: 8px 12px;
        border-radius: 10px;
        cursor: pointer;
        margin-right: 6px;
        font-weight: 600;
        transition: 0.25s;
        color: white;
    }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
    }

        .edit:hover {
            transform: scale(1.1);
        }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
    }

        .delete:hover {
            transform: scale(1.1);
        }

    .empty-message {
        text-align: center;
        color: #64748b;
        font-weight: 600;
        padding: 30px 10px;
    }

    /* MODALES */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: white;
        padding: 25px;
        border-radius: 18px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    }

    .modal-title {
        margin: 0 0 18px 0;
        font-size: 22px;
        font-weight: 600;
        color: #020617;
    }

    .modal-label {
        display: block;
        margin-bottom: 6px;
        margin-top: 12px;
        color: #334155;
        font-size: 14px;
        font-weight: 600;
    }

    .modal-input {
        width: 100%;
        margin-top: 2px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        outline: none;
        font-size: 14px;
    }

        .modal-input[disabled] {
            background: #f1f5f9;
            color: #64748b;
        }

    .modal-text {
        color: #334155;
        margin-top: 8px;
        margin-bottom: 0;
    }

    .modal-actions {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .modal-btn {
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-cancel {
        background: #e2e8f0;
        color: #1e293b;
    }

    .btn-save {
        background: linear-gradient(135deg, #3b82f6, #1e3a8a);
        color: white;
    }

    .btn-delete-confirm {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

    @@media (max-width: 768px) {
        .top-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            width: 100%;
            flex-wrap: wrap;
            border-radius: 18px;
        }

            .search-box input {
                width: 100%;
            }

        .btn-add {
            width: 100%;
        }

        table {
            display: block;
            overflow-x: auto;
        }
    }
</style>

<div class="wrapper">
    <div class="container">
        <h2>Administración de Entidades</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">@TempData["Success"]</div>
        }

        <div class="top-bar">
            <form method="get" class="search-box">
                <input type="text"
                       name="Busqueda"
                       value="@Model.Busqueda"
                       placeholder="Buscar por código o nombre..." />
                <button type="submit" class="btn-search">Buscar</button>
                <a asp-page="./Index" class="btn-clear">Limpiar</a>
            </form>

            <button type="button" class="btn-add" onclick="abrirCrear()">+ Nueva Entidad</button>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Entidades != null && Model.Entidades.Any())
                {
                    @foreach (var e in Model.Entidades)
                    {
                        <tr>
                            <td>@e.CodigoEntidad</td>
                            <td>@e.NombreInstitucion</td>
                            <td class="actions">
                                <button type="button"
                                        class="edit"
                                        onclick="editar('@e.EntidadId','@e.CodigoEntidad','@e.NombreInstitucion')">
                                    Editar
                                </button>

                                <button type="button"
                                        class="delete"
                                        onclick="eliminar('@e.EntidadId','@e.NombreInstitucion')">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="empty-message">No se encontraron entidades bancarias.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL CREAR -->
<div class="modal-overlay" id="modalCrear">
    <div class="modal-box">
        <h3 class="modal-title">Nueva Entidad</h3>

        <form method="post" asp-page-handler="Crear">
            <label class="modal-label">Código</label>
            <input type="text" name="Entidad.CodigoEntidad" class="modal-input" required />

            <label class="modal-label">Nombre</label>
            <input type="text" name="Entidad.NombreInstitucion" class="modal-input" required />

            <div class="modal-actions">
                <button type="button" class="modal-btn btn-cancel" onclick="cerrarCrear()">Cancelar</button>
                <button type="submit" class="modal-btn btn-save">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDITAR -->
<div class="modal-overlay" id="modalEditar">
    <div class="modal-box">
        <h3 class="modal-title">Editar Entidad</h3>

        <form method="post" asp-page-handler="Editar">
            <input type="hidden" name="EntidadEditar.EntidadId" id="editId" />
            <input type="hidden" name="EntidadEditar.CodigoEntidad" id="editCodigoHidden" />

            <label class="modal-label">Código</label>
            <input type="text" id="editCodigoVisible" class="modal-input" disabled />

            <label class="modal-label">Nombre</label>
            <input type="text" name="EntidadEditar.NombreInstitucion" id="editNombre" class="modal-input" required />

            <div class="modal-actions">
                <button type="button" class="modal-btn btn-cancel" onclick="cerrarEditar()">Cancelar</button>
                <button type="submit" class="modal-btn btn-save">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL ELIMINAR -->
<div class="modal-overlay" id="modalEliminar">
    <div class="modal-box">
        <h3 class="modal-title">Eliminar Entidad</h3>

        <p class="modal-text">¿Desea eliminar <strong id="nombreEliminar"></strong>?</p>

        <form method="post" asp-page-handler="Eliminar">
            <input type="hidden" name="id" id="deleteId" />

            <div class="modal-actions">
                <button type="button" class="modal-btn btn-cancel" onclick="cerrarEliminar()">Cancelar</button>
                <button type="submit" class="modal-btn btn-delete-confirm">Eliminar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const modalCrear = document.getElementById("modalCrear");
        const modalEditar = document.getElementById("modalEditar");
        const modalEliminar = document.getElementById("modalEliminar");

        const editId = document.getElementById("editId");
        const editCodigoHidden = document.getElementById("editCodigoHidden");
        const editCodigoVisible = document.getElementById("editCodigoVisible");
        const editNombre = document.getElementById("editNombre");

        const deleteId = document.getElementById("deleteId");
        const nombreEliminar = document.getElementById("nombreEliminar");

        function abrirCrear() {
            modalCrear.classList.add("activo");
        }

        function cerrarCrear() {
            modalCrear.classList.remove("activo");
        }

        function editar(id, codigo, nombre) {
            editId.value = id;
            editCodigoHidden.value = codigo;
            editCodigoVisible.value = codigo;
            editNombre.value = nombre;
            modalEditar.classList.add("activo");
        }

        function cerrarEditar() {
            modalEditar.classList.remove("activo");
        }

        function eliminar(id, nombre) {
            deleteId.value = id;
            nombreEliminar.innerText = nombre;
            modalEliminar.classList.add("activo");
        }

        function cerrarEliminar() {
            modalEliminar.classList.remove("activo");
        }

        window.onclick = function (e) {
            if (e.target === modalCrear) cerrarCrear();
            if (e.target === modalEditar) cerrarEditar();
            if (e.target === modalEliminar) cerrarEliminar();
        }
    </script>
}