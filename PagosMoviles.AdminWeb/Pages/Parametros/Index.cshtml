@page
@model PagosMoviles.AdminWeb.Pages.Parametros.IndexModel
@{
    ViewData["Title"] = "Administración de Parámetros";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .parametros-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .parametros-container {
        width: 95%;
        max-width: 1200px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .parametros-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .alert-success-custom {
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .alert-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-form {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        width: 100%;
        justify-content: space-between;
    }

    .search-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 260px;
        }

        .search-box button,
        .btn-clean {
            border: none;
            padding: 10px 18px;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-box button {
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            color: white;
        }

            .search-box button:hover {
                transform: scale(1.05);
            }

    .btn-clean {
        background: #e2e8f0;
        color: #1e293b;
    }

        .btn-clean:hover {
            transform: scale(1.05);
            background: #cbd5e1;
            color: #0f172a;
        }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-3px) scale(1.03);
        }

    .table-responsive {
        overflow-x: auto;
    }

    .parametros-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .parametros-table thead th {
            text-align: left;
            padding: 12px;
            color: #475569;
            font-size: 14px;
            border: none;
        }

        .parametros-table tbody tr {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

            .parametros-table tbody tr:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        .parametros-table td {
            padding: 15px;
            vertical-align: middle;
            border: none;
        }

        .parametros-table tbody tr td:first-child {
            border-radius: 16px 0 0 16px;
        }

        .parametros-table tbody tr td:last-child {
            border-radius: 0 16px 16px 0;
        }

    .actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

        .actions button {
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.25s;
        }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
        color: white;
    }

        .edit:hover {
            transform: scale(1.1);
        }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

        .delete:hover {
            transform: scale(1.1);
        }

    .empty-row td {
        text-align: center;
        color: #64748b;
        font-style: italic;
        padding: 25px;
    }

    .modal-dialog {
        max-width: 560px;
    }

    .modal-content {
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        overflow: hidden;
    }

    .modal-header,
    .modal-footer {
        border: none;
        padding-left: 24px;
        padding-right: 24px;
    }

    .modal-header {
        padding-top: 24px;
        padding-bottom: 10px;
    }

    .modal-body {
        padding: 10px 24px 10px 24px;
    }

    .modal-footer {
        padding-top: 10px;
        padding-bottom: 24px;
    }

    .modal-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #111827;
    }

    .form-label {
        font-weight: 600;
        color: #1f2937;
    }

    .form-control {
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 13px 14px;
        font-size: 1rem;
        color: #374151;
        background: #ffffff;
        transition: 0.25s;
        box-shadow: none;
    }

        .form-control:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
        }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 6px;
        display: block;
    }

    .btn-modal-cancel {
        background: #e2e8f0;
        color: #1f2937;
        border: none;
        border-radius: 12px;
        padding: 10px 16px;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-modal-cancel:hover {
            background: #cbd5e1;
        }

    .btn-modal-save {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 10px 16px;
        font-weight: 600;
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(37,99,235,0.30);
    }

        .btn-modal-save:hover {
            transform: scale(1.03);
        }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        z-index: 1050;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        .modal-overlay.activo {
            display: flex;
        }

    .modal-box {
        background: #ffffff;
        border-radius: 24px;
        padding: 28px;
        max-width: 460px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
    }

        .modal-box h5 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: #111827;
        }

        .modal-box p {
            color: #4b5563;
            margin-bottom: 24px;
            line-height: 1.5;
        }

    .modal-acciones {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-cancelar-eliminar {
        background: #e2e8f0;
        border: none;
        color: #1f2937;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-cancelar-eliminar:hover {
            background: #cbd5e1;
        }

    .btn-confirmar-eliminar {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-confirmar-eliminar:hover {
            transform: scale(1.03);
        }

    @@media (max-width: 768px) {
        .search-box input {
            width: 100%;
            min-width: 180px;
        }

        .search-form {
            align-items: stretch;
        }

        .search-left {
            width: 100%;
        }

        .modal-acciones {
            flex-direction: column;
        }

        .btn-cancelar-eliminar,
        .btn-confirmar-eliminar {
            width: 100%;
        }
    }
</style>

<div class="parametros-wrapper">
    <div class="parametros-container">
        <h2 class="parametros-title">Administración de Parámetros</h2>

        @if (!string.IsNullOrEmpty(Model.MensajeExito))
        {
            <div class="alert-success-custom">@Model.MensajeExito</div>
        }

        @if (!string.IsNullOrEmpty(Model.MensajeError))
        {
            <div class="alert-danger-custom">@Model.MensajeError</div>
        }

        <div class="top-bar">
            <form method="get" class="search-form">
                <div class="search-left">
                    <div class="search-box">
                        <input type="text" name="Busqueda" value="@Model.Busqueda" placeholder="Buscar por identificador..." />
                        <button type="submit">Buscar</button>
                    </div>
                    <a asp-page="/Parametros/Index" class="btn-clean">Limpiar</a>
                </div>

                <div>
                    <button type="button" class="btn-add" onclick="abrirNuevoParametro()">+ Nuevo Parámetro</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="parametros-table">
                <thead>
                    <tr>
                        <th>Identificador</th>
                        <th>Valor</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Parametros)
                    {
                        var json = System.Text.Json.JsonSerializer.Serialize(p,
                        new System.Text.Json.JsonSerializerOptions
                        {
                            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                        });

                        <tr>
                            <td><strong>@p.ParametroId</strong></td>
                            <td>@p.Valor</td>
                            <td>
                                <div class="actions">
                                    <button class="edit"
                                            type="button"
                                            data-parametro='@Html.Raw(json)'
                                            onclick="abrirEditarParametro(this)">
                                        Editar
                                    </button>

                                    <button type="button"
                                            class="delete"
                                            onclick="confirmarEliminarParametro('@p.ParametroId')">
                                        Eliminar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Parametros.Any())
                    {
                        <tr class="empty-row">
                            <td colspan="3">No se encontraron parámetros.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalParametro" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="Guardar" novalidate>
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Parámetro</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="Formulario.ParametroIdOriginal" id="fParamIdOriginal" />

                    <div class="mb-3">
                        <label class="form-label">
                            Identificador * <small class="text-muted">(mayúsculas, máx. 10 letras)</small>
                        </label>
                        <input asp-for="Formulario.ParametroId"
                               id="fParamId"
                               class="form-control"
                               style="text-transform:uppercase"
                               oninput="this.value = this.value.toUpperCase()"
                               placeholder="Ej: TASA" />
                        <span asp-validation-for="Formulario.ParametroId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Valor * <small class="text-muted">(máx. 500 caracteres)</small></label>
                        <textarea asp-for="Formulario.Valor"
                                  id="fParamValor"
                                  class="form-control"
                                  rows="3"></textarea>
                        <span asp-validation-for="Formulario.Valor" class="text-danger"></span>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-modal-save">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalEliminarParametro">
    <div class="modal-box">
        <h5>Confirmar eliminación</h5>
        <p>¿Realmente desea eliminar el parámetro <strong id="nombreParametroEliminar"></strong>?</p>

        <div class="modal-acciones">
            <button type="button" class="btn-cancelar-eliminar" onclick="cerrarModalEliminarParametro()">No</button>

            <form method="post" asp-page-handler="Eliminar" id="formEliminarParametro">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="idParametroEliminar" />
                <button type="submit" class="btn-confirmar-eliminar">Sí, eliminar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/parametros.js"></script>

    @if (Model.ReobrirModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var idOriginal = document.getElementById('fParamIdOriginal').value;
                document.getElementById('modalTitulo').innerText =
                    idOriginal ? 'Editar Parámetro' : 'Nuevo Parámetro';

                if (idOriginal) {
                    document.getElementById('fParamId').readOnly = true;
                }

                bootstrap.Modal.getOrCreateInstance(
                    document.getElementById('modalParametro')
                ).show();
            });
        </script>
    }

    <script>
        function confirmarEliminarParametro(id) {
            document.getElementById('idParametroEliminar').value = id;
            document.getElementById('nombreParametroEliminar').textContent = id;
            document.getElementById('modalEliminarParametro').classList.add('activo');
        }

        function cerrarModalEliminarParametro() {
            document.getElementById('modalEliminarParametro').classList.remove('activo');
        }

        document.getElementById('modalEliminarParametro').addEventListener('click', function (e) {
            if (e.target === this) cerrarModalEliminarParametro();
        });
    </script>
}