@page
@model PagosMoviles.AdminWeb.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Administración de Usuarios";
}

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .usuarios-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .usuarios-container {
        width: 95%;
        max-width: 1200px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .usuarios-title {
        margin-bottom: 25px;
        font-weight: 600;
        color: #020617;
        letter-spacing: 0.5px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

    .search-form {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        width: 100%;
        justify-content: space-between;
    }

    .search-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 6px;
        box-shadow: inset 0 3px 8px rgba(0,0,0,0.1);
    }

        .search-box input {
            border: none;
            outline: none;
            padding: 10px 15px;
            border-radius: 999px;
            background: transparent;
            width: 260px;
        }

        .search-box button,
        .btn-clean {
            border: none;
            padding: 10px 18px;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-box button {
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            color: white;
        }

            .search-box button:hover {
                transform: scale(1.05);
            }

    .btn-clean {
        background: #e2e8f0;
        color: #1e293b;
    }

        .btn-clean:hover {
            transform: scale(1.05);
            background: #cbd5e1;
            color: #0f172a;
        }

    .btn-add {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(37,99,235,0.5);
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-3px) scale(1.03);
        }

    .alert {
        border-radius: 14px;
        margin-bottom: 20px;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .usuarios-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .usuarios-table thead th {
            text-align: left;
            padding: 12px;
            color: #475569;
            font-size: 14px;
            border: none;
        }

        .usuarios-table tbody tr {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

            .usuarios-table tbody tr:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            }

        .usuarios-table td {
            padding: 15px;
            vertical-align: middle;
            border: none;
        }

        .usuarios-table tbody tr td:first-child {
            border-radius: 16px 0 0 16px;
        }

        .usuarios-table tbody tr td:last-child {
            border-radius: 0 16px 16px 0;
        }

    .role {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .admin {
        background: linear-gradient(135deg, #fecaca, #f87171);
        color: #7f1d1d;
    }

    .user {
        background: linear-gradient(135deg, #bfdbfe, #60a5fa);
        color: #1e3a8a;
    }

    .actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

        .actions button {
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.25s;
        }

    .edit {
        background: linear-gradient(135deg, #5879fc, #0d3dfb);
        color: white;
    }

        .edit:hover {
            transform: scale(1.1);
        }

    .delete {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
    }

        .delete:hover {
            transform: scale(1.1);
        }

    .empty-row td {
        text-align: center;
        color: #64748b;
        font-style: italic;
    }

    .modal-content {
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
    }

    .modal-header,
    .modal-footer {
        border: none;
    }

    .modal-title {
        font-weight: 600;
        color: #020617;
    }

    .form-label {
        font-weight: 600;
        color: #0f172a;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        padding: 10px 12px;
    }

    .btn-modal-cancel {
        background: #e2e8f0;
        color: #0f172a;
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-weight: 600;
    }

    .btn-modal-save {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .search-box input {
            width: 100%;
            min-width: 180px;
        }

        .search-form {
            align-items: stretch;
        }

        .search-left {
            width: 100%;
        }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<div class="usuarios-wrapper">
    <div class="usuarios-container">
        <h2 class="usuarios-title">Administración de Usuarios</h2>

        @if (!string.IsNullOrEmpty(Model.MensajeExito))
        {
            <div class="alert alert-success">@Model.MensajeExito</div>
        }
        @if (!string.IsNullOrEmpty(Model.MensajeError))
        {
            <div class="alert alert-danger">@Model.MensajeError</div>
        }

        <div class="top-bar">
            <form method="get" class="search-form">
                <div class="search-left">
                    <div class="search-box">
                        <input type="text"
                               name="Busqueda"
                               value="@Model.Busqueda"
                               placeholder="Buscar por nombre o identificación..." />
                        <button type="submit">Buscar</button>
                    </div>

                    <a asp-page="/Usuarios/Index" class="btn-clean">Limpiar</a>
                </div>

                <div>
                    <button type="button"
                            class="btn-add"
                            data-bs-toggle="modal"
                            data-bs-target="#modalUsuario"
                            onclick="prepararNuevo()">
                        + Nuevo Usuario
                    </button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="usuarios-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Identificación</th>
                        <th>Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Usuarios)
                    {
                        var json = System.Text.Json.JsonSerializer.Serialize(u,
                        new System.Text.Json.JsonSerializerOptions
                        {
                            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                        });

                        <tr>
                            <td>@u.NombreCompleto</td>
                            <td>@u.Email</td>
                            <td>@u.Identificacion</td>
                            <td>
                                @if (u.RolId == 1)
                                {
                                    <span class="role admin">Admin</span>
                                }
                                else
                                {
                                    <span class="role user">Usuario</span>
                                }
                            </td>
                            <td>
                                <div class="actions">
                                    <button class="edit"
                                            data-usuario='@Html.Raw(json)'
                                            onclick="abrirEditar(this)">
                                        Editar
                                    </button>

                                    <form method="post"
                                          asp-page-handler="Eliminar"
                                          style="display:inline"
                                          onsubmit="return confirm('¿Seguro que desea eliminar este usuario?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.UsuarioId" />
                                        <button type="submit" class="delete">Eliminar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Usuarios.Any())
                    {
                        <tr class="empty-row">
                            <td colspan="5">No se encontraron usuarios.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalUsuario" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Guardar">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="Formulario.UsuarioId" id="fUserId" />

                    <div class="mb-3">
                        <label class="form-label">Nombre Completo *</label>
                        <input asp-for="Formulario.NombreCompleto" class="form-control" />
                        <span asp-validation-for="Formulario.NombreCompleto" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input asp-for="Formulario.Email" type="email" class="form-control" />
                        <span asp-validation-for="Formulario.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Identificación *</label>
                        <input asp-for="Formulario.Identificacion" class="form-control" />
                        <span asp-validation-for="Formulario.Identificacion" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Teléfono * <small class="text-muted">(8 dígitos)</small></label>
                        <input asp-for="Formulario.Telefono" class="form-control" placeholder="12345678" />
                        <span asp-validation-for="Formulario.Telefono" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contraseña <small class="text-muted">(obligatoria al crear, mín. 6 caracteres)</small></label>
                        <input asp-for="Formulario.Password" type="password" class="form-control" />
                        <span asp-validation-for="Formulario.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select asp-for="Formulario.RolId" class="form-select">
                            <option value="1">Admin</option>
                            <option value="2">Usuario</option>
                        </select>
                    </div>

                    <div id="editOnlyFields" style="display:none;">
                        <hr />
                        <div class="mb-3">
                            <label class="form-label">Estado de cuenta</label>
                            <select asp-for="Formulario.Bloqueado" id="fBloqueado" class="form-select">
                                <option value="false">No Bloqueado</option>
                                <option value="true">Bloqueado</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Intentos Fallidos</label>
                            <input asp-for="Formulario.IntentosFallidos"
                                   id="fIntentosFallidos"
                                   type="number"
                                   min="0"
                                   class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-modal-save">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/usuarios.js" asp-append-version="true"></script>
}