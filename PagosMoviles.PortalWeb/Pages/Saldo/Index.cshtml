@page
@model PagosMoviles.PortalWeb.Pages.Saldo.IndexModel
@{
    ViewData["Title"] = "Consulta de Saldo";
}

<style>
    .page-title { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1.5rem; }
    .consulta-card {
        background: white; border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        padding: 2rem; max-width: 500px; margin-bottom: 1.5rem;
    }
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-weight: 600; color: #333; margin-bottom: 0.4rem; font-size: 0.95rem; }
    .form-group input {
        width: 100%; border: 1px solid #ced4da; border-radius: 6px;
        padding: 0.5rem 0.75rem; font-size: 0.95rem; box-sizing: border-box;
    }
    .form-group input:focus { outline: none; border-color: #0d6efd; box-shadow: 0 0 0 3px rgba(13,110,253,.15); }
    .text-danger { color: #dc3545; font-size: 0.82rem; margin-top: 0.25rem; display: block; }
    .btn-consultar {
        background: #0d6efd; color: white; border: none;
        padding: 0.6rem 1.75rem; border-radius: 6px; font-weight: 600;
        font-size: 0.95rem; cursor: pointer; width: 100%; margin-top: 0.5rem;
        transition: background 0.2s;
    }
    .btn-consultar:hover { background: #0b5ed7; }
    .resultado-card {
        background: white; border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        padding: 2rem; max-width: 500px;
        border-left: 5px solid #0d6efd;
    }
    .resultado-titulo { font-size: 1rem; color: #555; font-weight: 600; margin-bottom: 0.5rem; }
    .resultado-saldo { font-size: 2.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1rem; }
    .resultado-saldo span { font-size: 1.1rem; color: #555; margin-right: 0.4rem; }
    .resultado-detalle { font-size: 0.9rem; color: #666; }
    .resultado-detalle strong { color: #333; }
    .alert-danger {
        background: #f8d7da; color: #842029; border: 1px solid #f5c2c7;
        border-radius: 6px; padding: 0.75rem 1rem; margin-bottom: 1rem; max-width: 500px;
    }
    .alert-warning {
        background: #fff3cd; color: #664d03; border: 1px solid #ffecb5;
        border-radius: 6px; padding: 0.75rem 1rem; margin-bottom: 1rem; max-width: 500px;
    }
</style>

<div class="container mt-4">
    <h1 class="page-title">Consulta de Saldo</h1>

    @if (Model.MensajeError != null)
    {
        <div class="alert-danger">⚠️ @Model.MensajeError</div>
    }

    <div class="consulta-card">
        <form method="post">
            <div class="form-group">
                <label asp-for="Telefono">Número de teléfono</label>
                <input asp-for="Telefono" placeholder="Ej: 88888888" maxlength="20" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Identificacion">Identificación</label>
                <input asp-for="Identificacion" placeholder="Ej: 123456789" maxlength="20" />
                <span asp-validation-for="Identificacion" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-consultar">🔍 Consultar saldo</button>
        </form>
    </div>

    @if (Model.Resultado != null && Model.Resultado.Saldo > 0)
    {
        <div class="resultado-card">
            <p class="resultado-titulo">Saldo disponible</p>
            <p class="resultado-saldo">
                <span>₡</span>@Model.Resultado.Saldo.ToString("N2")
            </p>
            <div class="resultado-detalle">
                <p>📱 Teléfono: <strong>@Model.Resultado.Afiliacion.Telefono</strong></p>
                <p>🪪 Identificación: <strong>@Model.Resultado.Afiliacion.Identificacion</strong></p>
                <p>🏦 Cuenta: <strong>@Model.Resultado.Afiliacion.NumeroCuenta</strong></p>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}