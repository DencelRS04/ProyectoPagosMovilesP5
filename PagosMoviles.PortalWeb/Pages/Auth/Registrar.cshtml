@page
@model PagosMoviles.PortalWeb.Pages.Auth.RegistrarModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - DAYJA BANK</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(rgba(15,23,42,0.8), rgba(15,23,42,0.95)), url('https://images.unsplash.com/photo-1601597111158-2fceff292cdc?auto=format&fit=crop&w=1600&q=80') no-repeat center center/cover;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .card {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            width: 350px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

        h2 {
            margin-bottom: 20px;
        }

        .input {
            width: 100%;
            padding: 12px;
            margin: 8px 0;
            border-radius: 10px;
            border: none;
            outline: none;
            background: rgba(255,255,255,0.1);
            color: white;
        }

            .input::placeholder {
                color: #cbd5f5;
            }

            .input:focus {
                border: 1px solid #3b82f6;
            }

        .btn {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            border: none;
            border-radius: 10px;
            background: #2563eb;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn:hover {
                background: #1d4ed8;
                transform: translateY(-2px);
            }

        .success {
            background: rgba(34,197,94,0.2);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .error {
            background: rgba(239,68,68,0.2);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .link {
            margin-top: 15px;
            display: block;
            color: #93c5fd;
            text-decoration: none;
        }

            .link:hover {
                text-decoration: underline;
            }

        .logo {
            font-size: 1.2rem;
            margin-bottom: 10px;
            color: #60a5fa;
            font-weight: bold;
        }

        .tagline {
            font-size: 0.9rem;
            margin-bottom: 20px;
            opacity: 0.8;
        }
    </style>
</head>
<body>

    <div class="card">

        <div class="logo">DAYJA BANK</div>
        <div class="tagline">Su banco de confianza</div>

        <h2>Crear cuenta</h2>

        @if (!string.IsNullOrEmpty(Model.Mensaje))
        {
            <div class="success">@Model.Mensaje</div>
        }

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="error">@Model.Error</div>
        }

        <form method="post">

            <input class="input" name="Input.NombreCompleto" placeholder="Nombre completo" required />
            <input class="input" name="Input.Email" type="email" placeholder="Correo electrónico" required />
            <input class="input" name="Input.Identificacion" placeholder="Identificación" required />
            <input class="input" name="Input.Telefono" placeholder="Teléfono (8 dígitos)" required />
            <input class="input" name="Input.Password" type="password" placeholder="Contraseña" required />

            <button class="btn" type="submit">Registrarse</button>

        </form>

        <a class="link" href="/">← Volver al inicio</a>

    </div>

</body>
</html>