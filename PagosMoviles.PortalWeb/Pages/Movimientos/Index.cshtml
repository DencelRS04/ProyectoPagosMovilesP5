@page
@model PagosMoviles.PortalWeb.Pages.Movimientos.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Consultar Últimos Movimientos";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .movimientos-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 70px 15px 30px;
    }

    .movimientos-container {
        width: 95%;
        max-width: 900px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .page-title {
        font-size: 1.9rem;
        font-weight: 600;
        color: #020617;
        margin-bottom: 0.75rem;
        letter-spacing: 0.5px;
    }

    .page-subtitle {
        color: #64748b;
        margin-bottom: 1.75rem;
        font-size: 0.95rem;
    }

    .consulta-card,
    .resultado-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        padding: 2rem;
    }

    .consulta-card {
        max-width: 560px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 0.45rem;
            font-size: 0.95rem;
        }

        .form-group input {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            padding: 0.85rem 0.95rem;
            font-size: 0.95rem;
            box-sizing: border-box;
            background: #ffffff;
            transition: 0.25s;
        }

            .form-group input:focus {
                outline: none;
                border-color: #93c5fd;
                box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
            }

    .form-text-custom {
        color: #64748b;
        font-size: 0.82rem;
        margin-top: 0.35rem;
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 0.9rem 1.75rem;
        border-radius: 14px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        width: 100%;
        margin-top: 0.5rem;
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(37,99,235,0.30);
    }

        .btn-primary-custom:hover {
            transform: scale(1.02);
        }

    .alert-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 14px;
        padding: 0.95rem 1rem;
        margin-top: 1rem;
    }

    .alert-info-custom {
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #1d4ed8;
        border: 1px solid #93c5fd;
        border-radius: 14px;
        padding: 0.95rem 1rem;
    }

    .resultado-section {
        margin-top: 1.5rem;
    }

    .resultado-title {
        font-size: 1rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }

    .resultado-subtitle {
        font-size: 0.95rem;
        color: #334155;
        margin-bottom: 1rem;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .movimientos-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 0.5rem;
    }

        .movimientos-table thead th {
            text-align: left;
            padding: 14px 16px;
            color: #475569;
            font-size: 14px;
            border-bottom: 1px solid #e5e7eb;
            background: #f8fafc;
        }

        .movimientos-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid #f1f5f9;
            color: #1f2937;
        }

        .movimientos-table tbody tr:hover {
            background: #f8fbff;
        }

    .text-end {
        text-align: right;
    }

    .fw-bold {
        font-weight: 700;
    }

    .badge-custom {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .badge-success-custom {
        background: linear-gradient(135deg, #dcfce7, #86efac);
        color: #166534;
    }

    .badge-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fca5a5);
        color: #991b1b;
    }

    @@media (max-width: 768px) {
        .movimientos-container {
            padding: 20px;
        }

        .consulta-card,
        .resultado-card {
            padding: 1.25rem;
        }

        .page-title {
            font-size: 1.6rem;
        }
    }
</style>

<div class="movimientos-wrapper">
    <div class="movimientos-container">
        <h2 class="page-title">Consultar Últimos Movimientos</h2>
        <p class="page-subtitle">
            Ingrese el número de teléfono para consultar los últimos 5 movimientos registrados.
        </p>

        <div class="consulta-card">
            <form method="get">
                <div class="form-group">
                    <label for="telefono">Número de Teléfono</label>
                    <input type="text"
                           id="telefono"
                           name="telefono"
                           value="@Model.Telefono"
                           placeholder="Ej: 88889999"
                           maxlength="8"
                           required />
                    <div class="form-text-custom">Ingrese el número de teléfono (8 dígitos).</div>
                </div>

                <button type="submit" class="btn-primary-custom">
                    Consultar Movimientos
                </button>
            </form>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
        {
            <div class="alert-danger-custom">
                ⚠️ @Model.ErrorMensaje
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Telefono))
        {
            <div class="resultado-section">
                <div class="resultado-card">
                    <div class="resultado-title">Resultados</div>
                    <div class="resultado-subtitle">
                        Número consultado: <strong>@Model.Telefono</strong>
                    </div>

                    @if (Model.Movimientos != null && Model.Movimientos.Any())
                    {
                        <div class="table-responsive">
                            <table class="movimientos-table">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Tipo</th>
                                        <th class="text-end">Monto</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in Model.Movimientos)
                                    {
                                        <tr>
                                            <td>@m.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @if (m.TipoMovimiento == "CREDITO")
                                                {
                                                    <span class="badge-custom badge-success-custom">CRÉDITO</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-custom badge-danger-custom">DÉBITO</span>
                                                }
                                            </td>
                                            <td class="text-end fw-bold">
                                                @m.Monto.ToString("C")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (string.IsNullOrEmpty(Model.ErrorMensaje))
                    {
                        <div class="alert-info-custom">
                            No se encontraron movimientos para el número @Model.Telefono
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>