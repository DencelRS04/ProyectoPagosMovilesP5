@page
@model IndexModel
@{
    ViewData["Title"] = "Consultar Últimos Movimientos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="h5 mb-0">Consultar Últimos 5 Movimientos</h3>
                </div>

                <div class="card-body">
                    <form method="get">
                        <div class="mb-3">
                            <label for="telefono" class="form-label">Número de Teléfono</label>
                            <input type="text"
                                   class="form-control"
                                   id="telefono"
                                   name="telefono"
                                   value="@Model.Telefono"
                                   placeholder="Ej: 8095551234"
                                   maxlength="10"
                                   required />
                            <div class="form-text">Ingrese el número de teléfono a consultar (10 dígitos)</div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Consultar Movimientos
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Telefono))
    {
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h4 class="h6 mb-0">Resultados para: @Model.Telefono</h4>
                    </div>

                    @if (Model.Movimientos != null && Model.Movimientos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Teléfono Origen</th>
                                        <th>Teléfono Destino</th>
                                        <th class="text-end">Monto</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in Model.Movimientos)
                                    {
                                        <tr>
                                            <td>@m.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@m.TelefonoOrigen</td>
                                            <td>@m.TelefonoDestino</td>
                                            <td class="text-end">@m.Monto.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="card-body">
                            <div class="alert alert-info mb-0">
                                No se encontraron movimientos para el número @Model.Telefono
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>