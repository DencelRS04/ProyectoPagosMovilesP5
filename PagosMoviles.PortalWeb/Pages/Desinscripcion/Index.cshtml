@page
@model PagosMoviles.PortalWeb.Pages.Desinscripcion.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Desinscripción de Pagos Móviles";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top, #1e3a8a, #020617);
        min-height: 100vh;
    }

    .desinscripcion-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 70px 15px 30px;
    }

    .desinscripcion-container {
        width: 95%;
        max-width: 700px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }

    .page-title {
        font-size: 1.9rem;
        font-weight: 600;
        color: #020617;
        margin-bottom: 0.75rem;
        letter-spacing: 0.5px;
    }

    .page-subtitle {
        color: #64748b;
        margin-bottom: 1.75rem;
        font-size: 0.95rem;
    }

    .desinscripcion-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 0.45rem;
            font-size: 0.95rem;
        }

    .form-control {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 0.85rem 0.95rem;
        font-size: 0.95rem;
        box-sizing: border-box;
        background: #ffffff;
        transition: 0.25s;
    }

        .form-control:focus {
            outline: none;
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(59,130,246,0.12);
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.82rem;
        margin-top: 0.35rem;
        display: block;
    }

    .hint-text {
        color: #64748b;
        font-size: 0.82rem;
    }

    .alert-success-custom {
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 14px;
        padding: 0.95rem 1rem;
        margin-bottom: 1rem;
    }

    .alert-danger-custom {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 14px;
        padding: 0.95rem 1rem;
        margin-bottom: 1rem;
    }

    .btn-danger-custom {
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: white;
        border: none;
        padding: 0.9rem 1.75rem;
        border-radius: 14px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        width: 100%;
        margin-top: 0.5rem;
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(220,38,38,0.30);
    }

        .btn-danger-custom:hover {
            transform: scale(1.02);
        }

    @@media (max-width: 768px) {
        .desinscripcion-container {
            padding: 20px;
        }

        .desinscripcion-card {
            padding: 1.25rem;
        }

        .page-title {
            font-size: 1.6rem;
        }
    }
</style>

<div class="desinscripcion-wrapper">
    <div class="desinscripcion-container">
        <h2 class="page-title">Desinscripción de Pagos Móviles</h2>
        <p class="page-subtitle">
            Ingresa los datos de tu cuenta para desasociarla del servicio de Pagos Móviles.
        </p>

        @if (!string.IsNullOrEmpty(Model.MensajeExito))
        {
            <div class="alert-success-custom">
                <strong>✔</strong> @Model.MensajeExito
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.MensajeError))
        {
            <div class="alert-danger-custom">
                <strong>✖</strong> @Model.MensajeError
            </div>
        }

        <div class="desinscripcion-card">
            <form method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Identificación *</label>
                    <input asp-for="Formulario.Identificacion" class="form-control" placeholder="Ej: 123456789" />
                    <span asp-validation-for="Formulario.Identificacion" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Número de Cuenta *</label>
                    <input asp-for="Formulario.NumeroCuenta" class="form-control" placeholder="Ej: CR12345" />
                    <span asp-validation-for="Formulario.NumeroCuenta" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Número de Teléfono * <small class="hint-text">(8 dígitos, CR)</small>
                    </label>
                    <input asp-for="Formulario.Telefono" class="form-control" placeholder="Ej: 88001234" />
                    <span asp-validation-for="Formulario.Telefono" class="text-danger"></span>
                </div>

                <div class="d-grid">
                    <button type="submit"
                            class="btn-danger-custom"
                            onclick="return confirm('¿Está seguro de que desea desinscribirse de Pagos Móviles?');">
                        Desinscribirme
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}