@page
@model PagosMoviles.PortalWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DAYJA BANK</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background: linear-gradient(rgba(10,31,68,0.7), rgba(10,31,68,0.9)), url('https://images.unsplash.com/photo-1556740738-b6a63e27c4df');
            background-size: cover;
            background-position: center;
            height: 100vh;
            color: white;
        }

        /* HEADER */
        .landing-header {
            position: absolute;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-logo {
            height: 40px;
        }

        .brand-name {
            font-size: 1.2rem;
            font-weight: bold;
        }

        .header-buttons {
            display: flex;
            gap: 15px;
        }

        .login-trigger {
            padding: 10px 25px;
            border-radius: 25px;
            border: 1px solid rgba(255,255,255,0.6);
            background: transparent;
            color: white;
            cursor: pointer;
            transition: 0.3s;
        }

            .login-trigger:hover {
                background: white;
                color: #0a1f44;
            }

        /* MAIN */
        .landing-content {
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
        }

        .hero-card h1 {
            font-size: 3.5rem;
            margin-bottom: 15px;
            font-weight: 300;
        }

        .hero-card p {
            font-size: 1.2rem;
            opacity: 0.85;
        }

        /* FEATURES */
        .features {
            margin-top: 50px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            max-width: 900px;
        }

        .card {
            background: rgba(255,255,255,0.08);
            padding: 25px;
            border-radius: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
                background: rgba(255,255,255,0.15);
            }

        /* MODAL LOGIN */
        .modal-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
        }

            .modal-backdrop.show {
                display: flex;
            }

        .login-modal {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(15px);
            padding: 30px;
            border-radius: 20px;
            width: 350px;
            color: white;
        }

            .login-modal input {
                width: 100%;
                padding: 10px;
                margin-top: 5px;
                margin-bottom: 15px;
                border-radius: 10px;
                border: none;
            }

        .btn-accept {
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            border: none;
            background: white;
            color: #0a1f44;
            font-weight: bold;
            cursor: pointer;
        }

        .msg-box {
            margin-bottom: 10px;
            padding: 10px;
            border-radius: 10px;
        }

        .msg-warning {
            background: rgba(255, 193, 7, 0.2);
        }

        .msg-error {
            background: rgba(220, 53, 69, 0.2);
        }

        .close-btn {
            float: right;
            background: none;
            border: none;
            color: white;
            font-size: 20px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <header class="landing-header">
        <div class="brand">
            <!-- 🔥 LOGO ORIGINAL (NO SE TOCA) -->
            <img src="~/Imagenes/logofin.png" class="brand-logo" />
            <span class="brand-name">DAYJA BANK</span>
        </div>

        <div class="header-buttons">
            <button class="login-trigger" onclick="openLoginModal()">Iniciar Sesión</button>
            <a href="/Auth/Register" class="login-trigger">Registrarse</a>
        </div>
    </header>

    <!-- MAIN -->
    <main class="landing-content">
        <div class="hero-card">
            <h1>Bienvenido a DAYJA BANK</h1>
            <p>Su banco de confianza, seguridad y respaldo financiero.</p>

            <div class="features">
                <div class="card">
                    <h3>Pagos Móviles</h3>
                    <p>Transferencias rápidas y seguras desde cualquier lugar.</p>
                </div>

                <div class="card">
                    <h3>Accesible</h3>
                    <p>Diseñado para todos, fácil de usar.</p>
                </div>

                <div class="card">
                    <h3>Seguridad</h3>
                    <p>Protección avanzada de tus datos y dinero.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- LOGIN MODAL -->
    <div id="loginModal" class="modal-backdrop">
        <div class="login-modal">
            <button class="close-btn" onclick="closeLoginModal()">×</button>

            <h2>Ingreso al sistema</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
            {
                <div class="msg-box msg-warning">@Model.Mensaje</div>
            }

            @if (Model.Input != null && !string.IsNullOrWhiteSpace(Model.Input.MensajeError))
            {
                <div class="msg-box msg-error">@Html.Raw(Model.Input.MensajeError)</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <label>Usuario</label>
                <input type="text" name="Input.Usuario" value="@(Model.Input?.Usuario ?? "")" />

                <label>Contraseña</label>
                <input type="password" name="Input.Contrasena" />

                <button type="submit" class="btn-accept">Aceptar</button>
            </form>
        </div>
    </div>

    <script>
        function openLoginModal() {
            document.getElementById('loginModal').classList.add('show');
        }

        function closeLoginModal() {
            document.getElementById('loginModal').classList.remove('show');
        }

        @if ((Model.Input != null && !string.IsNullOrWhiteSpace(Model.Input.MensajeError)) || !string.IsNullOrWhiteSpace(Model.Mensaje))
        {
                <text>openLoginModal();</text>
        }
    </script>

</body>
</html>